<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_employee_badge_rother" model="report.paperformat">
        <field name="name">Employee Badge Rother</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">55</field>
        <field name="page_width">86</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="hr.hr_employee_print_badge" model="ir.actions.report">
        <field name="paperformat_id" ref="rother.paperformat_employee_badge_rother"/>
        <field name="report_name">rother.rother_report_employee_badge_inherit</field>
        <field name="report_file">rother.rother_report_employee_badge_inherit</field>
    </record>

    <template id="rother_report_employee_badge_inherit"
            inherit_id="hr.print_employee_badge"
            primary="True">
        <xpath expr="//div[@class='page']" position="replace">
            <style>
                .container, .container-fluid {
                    padding: 0 !important;
                    margin: 0 !important;
                    max-width: none !important;
                    width: 100% !important;
                }
                body, .o_body_pdf, .o_body_html {
                    padding: 0 !important;
                    margin: 0 !important;
                }
                .article {
                    padding: 0 !important;
                    margin: 0 !important;
                    min-height: 0 !important;
                }
                .o_report_layout_standard,
                .o_report_layout_boxed,
                .o_report_layout_bold,
                .o_report_layout_striped {
                    padding: 0 !important;
                    margin: 0 !important;
                }
            </style>

            <t t-foreach="docs" t-as="employee">

                <!-- CARA DELANTERA -->             
                <div style="height: 65mm; width: 104mm; border: 1px solid black; box-sizing: border-box; page-break-after: always">
                    <div style=" height: 65mm; width: 104mm; margin:0; padding:0; font-family:Arial, Helvetica, sans-serif; overflow:hidden; border:none; ">
                        <table style="height: 65mm; width: 104mm; table-layout:fixed; border:none; border-collapse: collapse;">
                            <tr style="border:none; height: 40mm" >
                                <td style="text-align:center; vertical-align:middle; padding:0.20cm 0.15cm 0.15cm 0.15cm; border:none;">
                                    <t t-if="employee.company_id.logo">
                                        <img src="/rother/static/src/img/logo_rother_i_d.png" alt="Logo" style="max-width:2.90cm; max-height:2.15cm; display:inline-block; border:none; outline:none; box-shadow:none;"/>
                                    </t>
                                </td>
                                <td style="width:4%; text-align:center; vertical-align:middle; border:none; padding:0;">
                                    <div style="width:2px; height:70%; background:#273b98; margin:0 auto;"></div>
                                </td>
                                <td style="width:50%; text-align:left; vertical-align:middle; padding:0.22cm 0.22cm 0.18cm 0.20cm; border:none;">
                                    <div style="font-size:8.6pt; color:#273b98; margin:0 0 0.18cm 0; font-weight:bold; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        <t t-esc="employee.name"/>
                                    </div>
                                    <div style="font-size:8.4pt; margin:0 0 0.03cm 0; color:#000000; font-weight:bold;">
                                        <t t-esc="employee.job_id.name or ''"/>
                                    </div>
                                    <div style="font-size:7.4pt; color:#7a7a7a; margin:0 0 0.18cm 0;">
                                        <t t-esc="employee.job_id.with_context(lang='en_US').name and employee.category_ids.name or ''"/>
                                    </div>
                                    <div style="font-size:6.8pt; color:#273b98; font-weight:normal; margin:0; line-height:1.15;">
                                        Desarrollos Tecnológicos e Industriales
                                    </div>
                                </td>
                            </tr>
                            <tr style="height: 25mm; border:none;">
                                <td colspan="3" style="padding: 0; margin: 0;">
                                    <div style="
                                        width:100%;
                                        height:100%;
                                        box-sizing:border-box;
                                        background:#273b98;
                                        background:-webkit-linear-gradient(left, #273b98 18%, #1e66c2 48%, #14b9e9 74%, #273b98 100%);
                                        display:table;
                                    ">
                                        <div style="display:table-cell; vertical-align:middle; text-align:center; padding:0 0.15cm;">
                                            <div style="color:#ffffff; font-size:7.8pt; font-weight:bold; line-height:1.3; margin-bottom:0.07cm;">
                                                C/ Fausto García Tena, nº 16, C-D · 14014 Córdoba (España)
                                            </div>
                                            <div style="color:#ffffff; font-size:8.2pt; font-weight:bold; line-height:1.3; margin-bottom:0.07cm;">
                                                Tel.: +(34) 957 08 82 21 · Móvil: +(34) <t t-esc="employee.mobile_phone or ''"/>
                                            </div>
                                            <div style="color:#ffffff; font-size:7.6pt; font-weight:bold; line-height:1.3; margin-bottom:0.07cm;">
                                                <t t-esc="employee.work_email or ''"/>
                                            </div>
                                            <div style="color:#ffffff; font-size:7.6pt; font-weight:bold; line-height:1.3;">
                                                www.rotherindustrial.es
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>    
                    </div>
                </div>

                <!-- CARA TRASERA -->
                <div style="height: 65mm; width: 104mm; border: 1px solid black; box-sizing: border-box;">
                    <div style=" height: 65mm; width: 104mm; margin:0; padding:0; font-family:Arial, Helvetica, sans-serif; overflow:hidden; border:none; ">
                        <table style="height: 65mm; width: 104mm; table-layout:fixed; border:none; border-collapse: collapse;">
                            <tr style="border:none; height: 40mm" >
                                <td style="text-align:center; vertical-align:middle; padding:0.20cm 0.15cm 0.15cm 0.15cm; border:none;">
                                    <t t-if="employee.company_id.logo">
                                        <img src="/rother/static/src/img/logo_rother_i_d.png" alt="Logo" style="max-width:2.90cm; max-height:2.15cm; display:inline-block; border:none; outline:none; box-shadow:none;"/>
                                    </t>
                                </td>
                                <td style="width:4%; text-align:center; vertical-align:middle; border:none; padding:0;">
                                    <div style="width:2px; height:70%; background:#273b98; margin:0 auto;"></div>
                                </td>
                                <td style="width:50%; text-align:left; vertical-align:middle; padding:0.22cm 0.22cm 0.18cm 0.20cm; border:none;">
                                    <div style="font-size:8.6pt; color:#273b98; margin:0 0 0.18cm 0; font-weight:bold; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        <t t-esc="employee.name"/>
                                    </div>
                                    <div style="font-size:8.4pt; margin:0 0 0.03cm 0; color:#000000; font-weight:bold;">
                                        <t t-esc="employee.job_id.name or ''"/>
                                    </div>
                                    <div style="font-size:7.4pt; color:#7a7a7a; margin:0 0 0.18cm 0;">
                                        <t t-esc="employee.job_id.with_context(lang='en_US').name and employee.category_ids.name or ''"/>
                                    </div>
                                    <div style="font-size:6.8pt; color:#273b98; font-weight:normal; margin:0; line-height:1.15;">
                                        Technological and Industrial Developments
                                    </div>
                                </td>
                            </tr>
                            <tr style="height: 25mm; border:none;">
                                <td colspan="3" style="padding: 0; margin: 0;">
                                    <div style="
                                        width:100%;
                                        height:100%;
                                        box-sizing:border-box;
                                        background:#273b98;
                                        background:-webkit-linear-gradient(left, #273b98 18%, #1e66c2 48%, #14b9e9 74%, #273b98 100%);
                                        display:table;
                                    ">
                                        <div style="display:table-cell; vertical-align:middle; text-align:center; padding:0 0.15cm;">
                                            <div style="color:#ffffff; font-size:7.8pt; font-weight:bold; line-height:1.3; margin-bottom:0.07cm;">
                                                C/ Fausto García Tena, nº 16, C-D · 14014 Córdoba (Spain)
                                            </div>
                                            <div style="color:#ffffff; font-size:8.2pt; font-weight:bold; line-height:1.3; margin-bottom:0.07cm;">
                                                Phone: +(34) 957 08 82 21 · Mobile: +(34) <t t-esc="employee.mobile_phone or ''"/>
                                            </div>
                                            <div style="color:#ffffff; font-size:7.6pt; font-weight:bold; line-height:1.3; margin-bottom:0.07cm;">
                                                <t t-esc="employee.work_email or ''"/>
                                            </div>
                                            <div style="color:#ffffff; font-size:7.6pt; font-weight:bold; line-height:1.3;">
                                                www.rotherindustrial.es
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>    
                    </div>
                </div>

            </t>
        </xpath>
    </template>
</odoo>