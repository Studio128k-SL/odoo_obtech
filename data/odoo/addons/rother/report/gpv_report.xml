                                <t t-set="base_imponible" t-value="subtotal - subtotal_descuento"/>
                                <t t-set="total_con_iva" t-value="sum(l.importe_total for l in lineas_producto)"/>
                                <t t-set="total_impuestos" t-value="total_con_iva - base_imponible"/>
                                <tr>
