                                        <td class="text-right" style="border: none; background: none; font-size: 11px;">
                                            <span t-esc="'-%.2f €' % subtotal_descuento"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td colspan="6" style="border: none; background: none;"></td>
                                    <td style="border: none; background: none; font-size: 11px;">Impuestos</td>
                                    <td class="text-right" style="border: none; background: none; font-size: 11px;">
                                        <span t-esc="'%.2f €' % total_impuestos"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="6" style="border: none; background: none;"></td>
                                    <td style="border: none; background: none; font-size: 16px; font-weight: bold; border-top: 2px solid #2c3e50;">Total</td>
                                    <td class="text-right" style="border: none; background: none; font-size: 16px; font-weight: bold; border-top: 2px solid #2c3e50;">
                                        <span t-esc="'%.2f €' % total_con_iva"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>