<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista lista GPV -->
    <record id="rother_gpv_tree_view" model="ir.ui.view">
        <field name="name">rother.gpv.tree</field>
        <field name="model">rother.gpv</field>
        <field name="arch" type="xml">
            <list string="Grupos de Compra">
                <field name="name" string="Número" />
                <field name="fecha" string="Fecha" />
                <field name="entregar_a" string="Entregar a"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario GPV -->
    <record id="rother_gpv_form_view" model="ir.ui.view">
        <field name="name">rother.gpv.form</field>
        <field name="model">rother.gpv</field>
        <field name="arch" type="xml">
            <form string="Grupo de Compra">
                <header>
                    <button name="action_cargar_lineas"
                            string="Cargar Líneas"
                            type="object"
                            class="btn-primary" />
                    <button name="action_generar_pv"
                            string="Generar PV"
                            type="object"
                            class="btn-secondary" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <field name="fecha" string="Fecha" />
                        <field name="entregar_a" string="Entregar a" />
                    </group>
                    <notebook>
                        <page string="Presupuestos">
                            <field name="presupuesto_ids">
                                <list>
                                    <field name="name" string="Número"/>
                                    <field name="fecha" string="Fecha" />
                                    <field name="importe_total" string="Importe Total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Líneas">
                            <field name="linea_ids">
                                <list editable="bottom">
                                    <field name="seccion_nombre" string="Proyecto" readonly="1"/>
                                    <field name="product_id" string="Producto" readonly="1"/>
                                    <field name="nombre" string="Nombre" readonly="1"/>
                                    <field name="cantidad" string="Cantidad" readonly="1"/>
                                    <field name="precio_unitario" string="Precio Unitario" readonly="1"/>
                                    <field name="taxes_id" string="Impuestos" widget="many2many_tags" readonly="1" />
                                    <field name="importe_total" string="Importe Total" readonly="1"/>
                                    <field name="proveedor_id" string="Proveedor" />
                                </list>
                            </field>
                        </page>
                        <page string="Pedidos Virtuales">
                            <field name="pv_ids">
                                <list>
                                    <field name="proveedor_id" string="Proveedor" />
                                    <field name="referencia_proveedor" string="Referencia Proveedor" />
                                    <field name="llegada_prevista" string="Llegada Prevista" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción GPV -->
    <record id="rother_gpv_action" model="ir.actions.act_window">
        <field name="name">Grupos de Compra</field>
        <field name="res_model">rother.gpv</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Vista formulario PV -->
    <record id="rother_pv_form_view" model="ir.ui.view">
        <field name="name">rother.pv.form</field>
        <field name="model">rother.pv</field>
        <field name="arch" type="xml">
            <form string="Pedido Virtual">
                <sheet>
                    <group>
                        <field name="proveedor_id" string="Proveedor"/>
                        <field name="referencia_proveedor" string="Referencia Proveedor"/>
                        <field name="llegada_prevista" string="Llegada Prevista"/>
                    </group>
                    <field name="linea_ids">
                        <list editable="bottom">
                            <field name="seccion_nombre" string="Proyecto" readonly="1"/>
                            <field name="product_id" string="Producto" readonly="1"/>
                            <field name="nombre" string="Nombre" readonly="1"/>
                            <field name="cantidad" string="Cantidad" readonly="1"/>
                            <field name="precio_unitario" string="Precio Unitario" readonly="1"/>
                            <field name="taxes_id" string="Impuestos" widget="many2many_tags" readonly="1"/>
                            <field name="importe_total" string="Importe Total" readonly="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Submenú GPV -->
    <menuitem id="rother_menu_gpv"
            name="Grupos de Compra"
            parent="rother_gestion_menu_root"
            action="rother_gpv_action"
            sequence="2" />
</odoo>