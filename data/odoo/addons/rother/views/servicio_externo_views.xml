<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Kanban -->
    <record id="rother_servicio_externo_kanban_view" model="ir.ui.view">
        <field name="name">rother.servicio.externo.kanban</field>
        <field name="model">rother.servicio.externo</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="precio_total_sin_iva"/>
                <field name="precio_total_con_iva"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image">
                            <field name="imagen" widget="image" options="{'size': [150, 150]}"/>
                        </div>
                        <div>
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="proveedor_id"/>
                            </div>
                            <div>
                                Sin IVA: <field name="precio_total_sin_iva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </div>
                            <div>
                                Con IVA: <field name="precio_total_con_iva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </div>
                            <div class="text-muted">
                                <field name="fecha_finalizacion"/>
                            </div>
                            <div class="text-muted" t-if="record.periodo_display.raw_value">
                                <field name="periodo_display"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>      
        </field>
    </record>

    <!-- Vista Lista -->
    <record id="rother_servicio_externo_tree_view" model="ir.ui.view">
        <field name="name">rother.servicio.externo.tree</field>
        <field name="model">rother.servicio.externo</field>
        <field name="arch" type="xml">
            <list string="Servicios Externos">
                <field name="name" string="Nombre"/>
                <field name="proveedor_id" string="Proveedor"/>
                <field name="precio" string="Precio" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="fecha_inicio" string="Fecha de Inicio"/>
                <field name="fecha_finalizacion" string="Fecha Finalización"/>
                <field name="precio_total_sin_iva" string="Total sin IVA" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="precio_total_con_iva" string="Total con IVA" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="rother_servicio_externo_form_view" model="ir.ui.view">
        <field name="name">rother.servicio.externo.form</field>
        <field name="model">rother.servicio.externo</field>
        <field name="arch" type="xml">
            <form string="Servicio Externo">
                <header>
                    <button string="Guardar" type="object" name="action_guardar"
                        class="btn-success" icon="fa-save"/>
                    <button name="action_renovar" type="object"
                        string="Renovar Servicio" class="btn-primary" icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                        <div>
                            <strong>FUNCIONAMIENTO</strong>
                            <button name="toggle_alerta"
                                    type="object"
                                    string="Ver más"
                                    class="btn btn-link p-0 ms-2"
                                    invisible="mostrar_alerta_completa" />
                            <button name="toggle_alerta"
                                    type="object"
                                    string="Ver menos"
                                    class="btn btn-link p-0 ms-2"
                                    invisible="not mostrar_alerta_completa" />
                        </div>   

                        <div invisible="not mostrar_alerta_completa">      
                            <ul>
                                <li>Introduce la <b>Fecha de Inicio</b> y el <b>Periodo de Renovación</b> (años, meses y/o días).
                                    La fecha de finalización se calculará automáticamente.</li>
                                <li>Puedes combinar los tres campos: por ejemplo, 1 año, 3 meses y 10 días.</li>
                                <li>Pulsa <b>«Guardar»</b> para que se guarden los cambios solamente. </li>
                                <li>Pulsa <b>«Renovar Servicio»</b> para extender la suscripción otro periodo completo
                                    a partir de la fecha de finalización actual.</li>
                                <li>Los <b>Servicios Extra</b> se suman al precio base para obtener el precio total.</li>
                            </ul>
                        </div>
                    </div>

                    <field name="imagen" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del servicio"/>
                        </h1>
                    </div>

                    <notebook>
                        <page string="Información General" name="info_general">
                            <group>
                                <group>
                                    <field name="proveedor_id" string="Proveedor"/>
                                    <field name="precio" string="Precio"
                                        widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="taxes_id" string="Impuestos" widget="many2many_tags"/>
                                </group>
                                <group>
                                    <field name="fecha_inicio" string="Fecha de Inicio"/>
                                    <label for="periodo_anios" string="Periodo de Renovación"/>
                                    <div class="o_row">
                                        <field name="periodo_anios" class="oe_inline" style="max-width:50px;"/>
                                        <span class="text-muted">año(s)</span>
                                        <field name="periodo_meses" class="oe_inline" style="max-width:50px;"/>
                                        <span class="text-muted">mes(es)</span>
                                        <field name="periodo_dias" class="oe_inline" style="max-width:50px;"/>
                                        <span class="text-muted">día(s)</span>
                                    </div>
                                    <field name="fecha_finalizacion" string="Fecha de Finalización"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </group>
                            <separator string="Descripción"/>
                            <field name="descripcion" placeholder="Descripción del servicio..."/>
                        </page>
                        <page string="Servicios Extra" name="servicios_extra">
                            <field name="extra_ids">
                                <list editable="bottom" string="Servicios Extra">
                                    <field name="name" string="Nombre"/>
                                    <field name="precio" string="Precio"/>
                                    <field name="fecha_finalizacion" string="Fecha Finalización"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="precio_total_sin_iva" string="Total sin IVA"
                                    widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="precio_total_con_iva" string="Total con IVA"
                                    widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </page>
                        <page string="Documentación" name="documentacion">
                            <group>
                                <field name="doc_archivo_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                        <page string="Pago" name="pago_servicio_extra">
                            <group>
                                <field name="forma_pago" string="Forma de Pago"/>

                                <field name="tarjeta_ultimos_4"
                                    string="Últimos 4 dígitos de la tarjeta"
                                    invisible="forma_pago != 'tarjeta'"
                                    required="forma_pago == 'tarjeta'" />
                                
                                <field name="cuenta_origen" string="Cuenta de Origen"
                                    invisible = "forma_pago != 'transferencia'"
                                    required = "forma_pago == 'transferencia'" />

                                <field name="cuenta_destino" string="Cuenta de Destino" 
                                    invisible = "forma_pago != 'transferencia'"
                                    required = "forma_pago == 'transferencia'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda del balance -->
    <record id="rother_servicio_externo_balance_search" model="ir.ui.view">
        <field name="name">rother.servicio.externo.report.search</field>
        <field name="model">rother.servicio.externo.report</field>
        <field name="arch" type="xml">
            <search string="Análisis de Balance">
                <filter string="Contrataciones" name="filter_inicio" domain="[('tipo', '=', 'inicio')]"/>
                <filter string="Renovaciones" name="filter_renovacion" domain="[('tipo', '=', 'renovacion')]"/>
                <separator/>
                <filter string="Este año" name="filter_anio_actual"
                        domain="[('anio', '=', context_today().strftime('%Y'))]"/>

                <separator/>
                <group expand="1" string="Agrupar por">
                    <filter string="Proveedor" name="group_proveedor" context="{'group_by': 'proveedor_id'}"/>
                    <filter string="Año" name="group_anio" context="{'group_by': 'anio'}"/>
                    <filter string="Mes" name="group_mes" context="{'group_by': 'mes'}"/>
                    <filter string="Servicio" name="group_servicio" context="{'group_by': 'name_display'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista gráfica del balance -->
    <record id="rother_servicio_externo_balance_view" model="ir.ui.view">
        <field name="name">rother.servicio.externo.report.graph</field>
        <field name="model">rother.servicio.externo.report</field>
        <field name="arch" type="xml">
            <graph string="Balance Anual" type="line" stacked="0">
                <field name="name_display" type="col"/>
                <field name="precio_total" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Vista en tabla del balance -->
    <record id="rother_servicio_externo_balance_pivot" model="ir.ui.view">
        <field name="name">rother.servicio.externo.report.pivot</field>
        <field name="model">rother.servicio.externo.report</field>
        <field name="arch" type="xml">
            <pivot string="Balance Anual">
                <field name="mes" type="row"/>
                <field name="name_display" type="row"/>
                <field name="proveedor_id" type="col"/>
                <field name="precio_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action del balance -->
    <record id="rother_balance_servicios_action" model="ir.actions.act_window">
        <field name="name">Balance</field>
        <field name="res_model">rother.servicio.externo.report</field>
        <field name="view_mode">graph,pivot</field>
        <field name="view_id" ref="rother_servicio_externo_balance_view"/>
        <field name="search_view_id" ref="rother_servicio_externo_balance_search"/>
        <field name="context">{
            'search_default_filter_anio_actual': 1,
            'search_default_group_mes': 1, 
            'search_default_group_servicio': 1
        }</field>
    </record>

    <!-- Action de servicios -->
    <record id="rother_servicio_externo_action" model="ir.actions.act_window">
        <field name="name">Servicios</field>
        <field name="res_model">rother.servicio.externo</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- Menús -->
    <menuitem id="rother_menu_servicios_externos" 
            name="Servicios" 
            sequence="100"/>

    <menuitem id="rother_menu_servicios_list" 
            name="Servicios" 
            parent="rother_menu_servicios_externos" 
            action="rother_servicio_externo_action" 
            sequence="1"/>

    <menuitem id="rother_menu_balance"
            name="Balance"
            parent="rother_menu_servicios_externos"
            action="rother_balance_servicios_action"
            sequence="2"/>
</odoo>