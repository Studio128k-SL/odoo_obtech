<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Herencia del form nativo -->
    <record id="rother_product_form_view" model="ir.ui.view">
        <field name="name">rother.product.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            
            <!-- Ref. Fabricante en Vista Previa -->
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="x_Ref_fab" string="Referencia Fabricante"/>
            </xpath>

            <!-- Ocultamos el botón nativo de Imprimir Etiquetas para que solo se use 'Impresiones' -->
            <xpath expr="//button[@name='action_open_label_layout']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Página de Impresiones -->
            <xpath expr="//notebook" position="inside">
                <page string="Impresiones" name="impresiones">
                    <group string="Configuración de impresión">
                        <div class="o_field_widget">
                            <button name="%(rother.rother_product_label_wizard_action)d"
                                string="Configurar e imprimir etiqueta"
                                type="action"
                                class="btn-primary" />
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Herencia del Kanban nativo -->
    <record id="rother_product_kanban_inherit" model="ir.ui.view">
        <field name="name">rother.product.kanban.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="x_Ref_fab"/>
            </xpath>
            <xpath expr="//div[hasclass('mb-1')]" position="after">
                <div t-if="record.x_Ref_fab.value">
                    Ref. Fab: <t t-esc="record.x_Ref_fab.value"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Herencia para el kanban del catálogo -->
    <record id="rother_product_catalog_kanban_inherit" model="ir.ui.view">
        <field name="name">rother.product.catalog.kanban.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_view_kanban_catalog"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='o_kanban_price']" position="before">
                <div t-if ="record.x_Ref_fab.value">
                    Ref. Fab: <field name="x_Ref_fab" />
                </div>
            </xpath>
        </field>
    </record>

    <!-- Herencias para poder buscar por Ref. Fab -->
    <record id="rother_product_search_inherit" model="ir.ui.view">
        <field name="name">rother.product.search.catalog.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_view_search_catalog"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_Ref_fab" string="Ref. Fabricante" filter_domain="[('x_Ref_fab', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>
    <record id="rother_product_template_search_inherit" model="ir.ui.view">
        <field name="name">rother.product.template.search.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_Ref_fab" string="Ref. Fabricante" filter_domain="[('x_Ref_fab', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>

</odoo>