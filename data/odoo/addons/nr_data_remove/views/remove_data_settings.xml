<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record id="view_remove_data" model="ir.ui.view">
        <field name="name">Remove Data</field>
        <field name="model">res.config.settings</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="odooApp Customize Settings" class="oe_form_configuration">
                <div class="mt16 o_settings_container" name="data-clean">
                    <span>
                        <h2>Data Cleaning (Be careful to do that!)</h2>
                        <h2>
                            Data is deleted directly from the database table using queries, once you done, it is not
                            reversible !
                        </h2>
                    </span>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Remove All</span>
                        <button string="Delete All Transactions Except Master Data" type="action" name="%(action_remove_all)d" confirm="Please confirm to delete the data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Sale</span>
                        <button string="Delete All Sales Order" type="action" name="%(action_remove_sales)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">POS</span>
                        <button string="Delete All POS Order" type="action" name="%(action_remove_pos)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Purchase</span>
                        <button string="Delete All Purchase Order and Requisition" type="action" name="%(action_remove_purchase)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Expense</span>
                        <button string="Delete All Expense and Sheet" type="action" name="%(action_remove_expense)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">MRP</span>
                        <button string="Delete All Manufacturing Order" type="action" name="%(action_remove_mrp)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                        |
                        <button string="Delete All BOM" type="action" name="%(action_remove_mrp_bom)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Inventory</span>
                        <button string="Delete All Move/Picking/Package/Lot" type="action" name="%(action_remove_inventory)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">
                            Accounting
                            <span title="Values set here are company-specific." groups="base.group_multi_company"/>
                        </span>
                        <button string="Delete All Voucher/Invoice/Bill" type="action" name="%(action_remove_account)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                        |
                        <button string="Clean and reset Account Chart" type="action" name="%(action_remove_account_chart)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Project</span>
                        <button string="Delete All Project/Task/Forecast" type="action" name="%(action_remove_project)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Quality</span>
                        <button string="Delete All Quality" type="action" name="%(action_remove_quality)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                        |
                        <button string="Delete All Quality Setting" type="action" name="%(action_remove_quality_setting)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Website And Blog</span>
                        <button string="Delete All Website/Blog" type="action" name="%(action_remove_website)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                    </div>
                    <div class="col-12 col-lg-12 mb4">
                        <span class="col-3 col-lg-2 text-start">Base Models</span>
                        <button string="Delete All Product" type="action" name="%(action_remove_product)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                        |
                        <button string="Delete All Product Attribute" type="action" name="%(action_remove_product_attribute)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                        |
                        <button string="Delete All Message" type="action" name="%(action_remove_message)d" confirm="Please confirm to delete the select data?" class="oe_highlight"/>
                        |
                        <button string="Reset Category And Location Complete Name" type="action" name="%(action_reset_cat_loc_name)d" class="oe_highlight"/>
                    </div>
                </div>
            </form>
        </field>
    </record>

    <record id="action_remove_data" model="ir.actions.act_window">
        <field name="name">Remove Data</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_remove_data"/>
        <field name="target">current</field>
    </record>

    <menuitem
            id="menu_remove_data"
            name="Remove Data"
            action="action_remove_data"
            parent="base.menu_administration"
            sequence="1"
            groups="base.group_system"/>
  </data>
</odoo>
